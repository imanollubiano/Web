---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug);

if (!post) return Astro.redirect('/blog');

const { Content } = await post.render();

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={`${post.data.title} — Imanol Lubiano`} description={post.data.description}>
  <article class="prose-wrap">
    <div class="prose-header">
      <a href="/blog" class="back-link">← Volver al blog</a>

      <div class="post-meta">
        <time datetime={post.data.date.toISOString()} class="post-date">
          {formatDate(post.data.date)}
        </time>
        <div class="post-tags">
          {post.data.tags.map((tag) => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>
      </div>

      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
      <div class="post-divider"></div>
    </div>

    <div class="prose">
      <Content />
    </div>

    <div class="prose-footer">
      <div class="post-divider"></div>
      <a href="/blog" class="back-link">← Volver al blog</a>
    </div>
  </article>
</BaseLayout>

<style>
  .prose-wrap {
    max-width: 720px;
    margin-inline: auto;
    padding: calc(var(--nav-h) + 4rem) 2.5rem 6rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
    margin-bottom: 2.5rem;
  }

  .back-link:hover { color: var(--accent); }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 800;
    color: var(--heading);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-desc {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .post-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
    margin-bottom: 2.5rem;
  }

  /* ── PROSE STYLES ── */
  .prose {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--text);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--heading);
    letter-spacing: -0.01em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--heading);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.4rem;
  }

  .prose :global(strong) {
    color: var(--heading);
    font-weight: 500;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }

  .prose :global(a:hover) { opacity: 0.75; }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.4rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(li::marker) {
    color: var(--accent);
  }

  /* Inline code */
  .prose :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.15em 0.4em;
    color: var(--accent);
  }

  /* Code blocks (Shiki) */
  .prose :global(pre) {
    background: var(--bg2) !important;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .prose :global(pre code) {
    background: none !important;
    border: none !important;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.75rem;
    font-size: 0.9rem;
  }

  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 1rem;
    text-align: left;
  }

  .prose :global(td) {
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 1rem;
    color: var(--text);
    vertical-align: top;
  }

  .prose :global(tr:last-child td) { border-bottom: none; }
  .prose :global(tr:hover td) { background: var(--bg2); }

  /* Blockquote */
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1.25rem;
    margin-left: 0;
    margin-bottom: 1.4rem;
    color: var(--muted);
    font-style: italic;
  }

  .prose-footer {
    margin-top: 4rem;
  }

  @media (max-width: 640px) {
    .prose-wrap {
      padding: calc(var(--nav-h) + 2.5rem) 1.25rem 4rem;
    }

    .prose :global(pre) {
      padding: 1rem;
      font-size: 0.78rem;
    }
  }
</style>
