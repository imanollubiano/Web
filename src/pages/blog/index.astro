---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Blog — Imanol Lubiano"
  description="Artículos técnicos sobre sysadmin, redes, seguridad e infraestructura IT escritos desde la experiencia real."
>
  <section class="section blog-section">
    <div class="container">
      <p class="section-label">Blog</p>
      <h1 class="blog-heading">Artículos<br />técnicos</h1>
      <p class="section-intro">
        Notas y guías sobre infraestructura, redes y seguridad. Escritas desde producción, no desde el tutorial.
      </p>

      {posts.length === 0 ? (
        <p class="blog-empty">No hay artículos publicados todavía.</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-card-meta">
                <time datetime={post.data.date.toISOString()} class="blog-date">
                  {formatDate(post.data.date)}
                </time>
              </div>
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-card-tags">
                {post.data.tags.map((tag) => (
                  <span class="project-tag">{tag}</span>
                ))}
              </div>
              <span class="blog-card-cta">Leer artículo →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-section {
    min-height: calc(100vh - var(--nav-h));
    padding-top: calc(var(--nav-h) + 4rem);
  }

  .blog-heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .blog-empty {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 3rem;
  }

  .blog-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 3rem;
  }

  .blog-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    text-decoration: none;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    position: relative;
    overflow: hidden;
  }

  .blog-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }

  .blog-card:hover {
    border-color: rgba(37, 99, 235, 0.4);
    box-shadow: 0 0 0 1px rgba(37, 99, 235, 0.2), 0 8px 32px rgba(37, 99, 235, 0.12);
    transform: translateY(-2px);
  }

  .blog-card:hover::before { transform: scaleX(1); }

  .blog-card-meta {
    margin-bottom: 0.75rem;
  }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--heading);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .blog-card-desc {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .blog-card-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }

  .blog-card:hover .blog-card-cta { opacity: 0.75; }

  @media (max-width: 640px) {
    .blog-section { padding-top: calc(var(--nav-h) + 2.5rem); }
    .blog-card { padding: 1.5rem; }
  }
</style>
