---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Imanol Lubiano">
  <section class="not-found">
    <div class="container">
      <p class="code">404</p>
      <h1>Página no encontrada</h1>
      <p class="msg">Esta ruta no existe. Vuelve al inicio.</p>
      <a href="/" class="btn-primary">← Volver al inicio</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .code {
    font-family: var(--font-mono);
    font-size: 7rem;
    color: var(--accent);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .msg {
    color: var(--muted);
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>
